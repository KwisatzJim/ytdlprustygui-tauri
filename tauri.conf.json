{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT-DLP Rusty GUI",
  "version": "0.2.0",
  "identifier": "com.jim.ytdlprustygui",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "YT-DLP Rusty GUI",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
